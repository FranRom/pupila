.playwright-mcp/

# Personal / AI-generated artifacts. These reflect your CV, applications,
# scoring preferences, and the LLM's per-job verdicts — they should NOT be
# committed on a public fork. The aggregator and the UI surface a clear
# "missing — generate it" gate when these files don't exist; there is no
# `*.example.*` template to copy.
config/candidate-brief.md
config/applied.json
config/preferences.json
config/profile.json
config/slugs.local.json
config/cv.pdf
config/cv.docx
config/cv.md
config/cv.txt
data/jobs.json
data/ai-reviews.json
data/feed.xml
JOBS.md
data/archive/*
!data/archive/.gitkeep
data/applications/*
!data/applications/.gitkeep
data/jobs-bodies.json
data/raw/*
!data/raw/.gitkeep
data/apply-queue.json
data/apply-worker.pid
data/swipe-skips.json

# Local launchd / cron schedule logs
data/launchd-*.log
data/cron-*.log

.DS_Store
*.log
.env
.env.*
!.env.example

# Local planning scratch — design proposals live in Linear, not the repo.
openspec/

# Per-IDE agent integration files — local tooling for whichever editor each
# developer uses.
.claude/*
# Exception: project-specific Claude Code skills (`pupila-*`) ship with the
# repo so contributors get the agent guidance automatically. Provider-generic
# skills (vitest, vite, etc.) stay local-only.
!.claude/skills/
.claude/skills/*
!.claude/skills/pupila-*/
.codebuddy/
.continue/
.junie/
.kiro/
